{
	"name": "ng-error-tooltips-demo",
	"version": "0.22.0",
	"scripts": {
		"ng": "ng",
		"start": "ng serve --configuration=development --port 4206",
		"build": "ng build",
		"watch": "ng build --watch --configuration development",
		"test": "ng test --coverage",
		"test:watch": "ng test --watch",
		"test:ci": "ng test --watch=false --coverage",
		"reinstall": "npx -y -p rimraf@latest rimraf node_modules && npm ci",
		"deploy": "ng build --configuration=production --base-href \"/ng-error-tooltips/\" && node copyIndexTo404.js"
	},
	"private": true,
	"dependencies": {
		"@angular/common": "22.0.0",
		"@angular/compiler": "22.0.0",
		"@angular/core": "22.0.0",
		"@angular/forms": "22.0.0",
		"@angular/platform-browser": "22.0.0",
		"@angular/platform-browser-dynamic": "22.0.0",
		"@angular/router": "22.0.0",
		"bootstrap": "5.3.8",
		"ng-error-tooltips": "file:../ng-error-tooltips-lib/dist/ng-error-tooltips",
		"rxjs": "7.8.2",
		"tslib": "2.8.1"
	},
	"devDependencies": {
		"@angular/build": "^22.0.0",
		"@angular/cli": "~22.0.0",
		"@angular/compiler-cli": "^22.0.0",
		"@types/node": "^25.9.1",
		"@vitest/coverage-v8": "4.1.8",
		"jsdom": "^29.1.1",
		"typescript": "6.0.3",
		"vitest": "4.1.8"
	}
}