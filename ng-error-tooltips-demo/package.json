    "@angular/platform-browser-dynamic": "22.0.0",
    "@angular/router": "22.0.0",
    "bootstrap": "5.3.8",
    "ng-error-tooltips": "file:../ng-error-tooltips-lib/dist/ng-error-tooltips",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "22.0.0",
    "@angular/compiler-cli": "22.0.0",
    "@nrwl/jest": "19.8.4",
    "@types/jest": "30.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
