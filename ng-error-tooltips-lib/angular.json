{
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ng-error-tooltips": {
      "projectType": "library",
      "root": "projects/ng-error-tooltips",
      "sourceRoot": "projects/ng-error-tooltips/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/ng-error-tooltips/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ng-error-tooltips/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ng-error-tooltips/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
		"test": {
			"builder": "@angular/build:unit-test",
			"options": {
				"tsConfig": "tsconfig.spec.json",
				"runnerConfig": "vitest.config.ts",
				"providersFile": "projects/ng-error-tooltips/src/test-providers.ts",
				"coverage": true,
				"coverageInclude": [
					"projects/ng-error-tooltips/src/**/*.ts"
				],
				"coverageExclude": [
					"projects/ng-error-tooltips/src/**/*.spec.ts",
					"projects/ng-error-tooltips/src/test-providers.ts",
					"projects/ng-error-tooltips/src/public-api.ts",
					"projects/ng-error-tooltips/src/lib/**/*.module.ts",
					"projects/ng-error-tooltips/src/lib/**/mocks/**/*.ts",
					"projects/ng-error-tooltips/src/lib/tooltip/placement.type.ts",
					"projects/ng-error-tooltips/src/lib/provide-error-tooltips.ts"
				],
				"coverageReporters": [
					"html",
					"text",
					"text-summary",
					"lcov"
				]
			}
		}
      }
    }
  },
  "cli": {
    "analytics": false,
    "schematicCollections": [
      "@angular-devkit/schematics-cli"
    ]
  }
}
